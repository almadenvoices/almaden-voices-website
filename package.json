{
  "name": "almadenvoices",
  "version": "1.0.0",
  "private": true,
  "main": "server.js",
  "scripts": {
    "server": "node server.js",
    "server:dev": "nodemon server.js",
    "client": "npm start --prefix client",
    "client:build": "npm run build --prefix client",
    "dev": "concurrently \"npm run server:dev\" \"npm run client\"",
    "build": "npm run client:build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "node-fetch": "^2.7.0",
    "nodemailer": "^7.0.10",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "nodemon": "^3.1.0"
  }
}
