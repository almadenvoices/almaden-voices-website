{
  "name": "almadenvoices",
  "version": "1.0.0",
  "private": true,
  "main": "server.js",
  "scripts": {
    "server": "NODE_ENV=development node server.js",
    "server:dev": "NODE_ENV=development nodemon server.js",
    "server:prod": "NODE_ENV=production node server.js",
    "server:gcp": "NODE_ENV=production USE_GCP_SECRETS=true node server.js",
    "client": "npm start --prefix client",
    "client:build": "npm run build --prefix client",
    "dev": "concurrently \"npm run server:dev\" \"npm run client\"",
    "build": "npm run client:build",
    "start": "npm run server:prod"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^6.1.1",
    "@google-cloud/storage": "^7.19.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "node-fetch": "^2.7.0",
    "nodemailer": "^7.0.10",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "nodemon": "^3.1.0"
  }
}
